# Auto-Grasp-Pipeline 环境变量配置
# 复制为 .env，填写实际路径后加载：source .env

# Python 解释器路径（含 youtube-transcript-api 和 faster-whisper 的虚拟环境）
# 不设置则自动使用运行脚本的当前 Python
VENV_PYTHON=/usr/local/bin/python3

# YouTube cookies.txt 文件的绝对路径（Netscape 格式，由浏览器插件导出）
# 推荐路径：放在项目外，避免意外提交到 git
YOUTUBE_COOKIES=/Users/yourname/.config/auto-grasp/youtube_cookies.txt

# collect_notes.py 脚本绝对路径（n8n 用）
COLLECT_NOTES_SCRIPT=/absolute/path/to/scripts/collect_notes.py

# 笔记输出目录（n8n 用）
NOTES_OUT_DIR=/absolute/path/to/output
